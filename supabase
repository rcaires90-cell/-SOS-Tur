-- ── AGENCIES (clientes do plantão) ───────────────
create table public.agencies (
  id              uuid default uuid_generate_v4() primary key,
  created_at      timestamptz default now(),
  name            text not null,
  cnpj            text unique,
  contact_name    text,
  contact_phone   text not null,
  contact_email   text,
  plan            text default 'essencial' check (plan in ('essencial','profissional','enterprise')),
  stripe_sub_id   text,
  active          boolean default true,
  max_pax_monthly int default 50,   -- limite mensal de passageiros
  pax_used_month  int default 0,
  sla_minutes     int default 30,   -- SLA em minutos por plano
  notes           text
);

-- ── EMERGENCY AGENTS ─────────────────────────────
create table public.emergency_agents (
  id             uuid default uuid_generate_v4() primary key,
  created_at     timestamptz default now(),
  name           text not null,
  email          text unique not null,
  phone          text not null,
  status         text default 'offline' check (status in ('available','busy','on_call','offline')),
  active_tickets int default 0,
  shift          text check (shift in ('morning','afternoon','night','flexible')),
  languages      text[] default '{pt-BR}',
  specialties    text[] default '{}',    -- ['flight_ops','hotel','visa','medical']
  resolved_today int default 0,
  avg_rating     numeric(3,2)
);

-- ── EMERGENCY TICKETS ─────────────────────────────
create table public.emergency_tickets (
  id                      uuid default uuid_generate_v4() primary key,
  created_at              timestamptz default now(),
  updated_at              timestamptz default now(),
  ticket_number           text unique not null,          -- ex: EM-20250315-0041
  agency_id               uuid references public.agencies on delete restrict not null,
  assigned_agent_id       uuid references public.emergency_agents,
  incident_type           text not null check (incident_type in (
    'flight_cancellation','missed_connection','emergency_medical',
    'overbooking_hotel','lost_baggage','documentation_issue','refund_dispute','other'
  )),
  priority                text not null check (priority in ('P1','P2','P3')),
  status                  text default 'open' check (status in ('open','assigned','in_progress','waiting_airline','resolved','closed')),
  description             text not null,
  passengers              jsonb default '[]',            -- [{name, document, phone}]
  flight_number           text,
  route                   text,                          -- ex: 'GRU→MIA'
  contact_phone           text not null,
  contact_email           text,
  sla_deadline            timestamptz not null,
  sla_breached            boolean default false,
  first_response_at       timestamptz,
  resolved_at             timestamptz,
  resolved_by             uuid references public.emergency_agents,
  resolution              text,
  actions_taken           text[],
  resolution_cost         numeric(10,2) default 0,       -- custo de realocação, hotel, etc.
  response_time_seconds   int,                           -- tempo até resolução
  satisfaction_rating     int check (satisfaction_rating between 1 and 5),
  internal_notes          text
);

create trigger set_et_updated_at before update on public.emergency_tickets
  for each row execute procedure public.handle_updated_at();

create index idx_et_agency on public.emergency_tickets(agency_id);
create index idx_et_status on public.emergency_tickets(status);
create index idx_et_priority on public.emergency_tickets(priority);
create index idx_et_sla on public.emergency_tickets(sla_deadline) where status in ('open','assigned','in_progress');

-- ── TICKET EVENTS (timeline) ─────────────────────
create table public.ticket_events (
  id          bigserial primary key,
  created_at  timestamptz default now(),
  ticket_id   uuid references public.emergency_tickets on delete cascade,
  agent_id    uuid references public.emergency_agents,
  type        text not null,   -- 'created','assigned','note','status_change','call','resolved'
  content     text,
  metadata    jsonb default '{}'
);

create index idx_te_ticket on public.ticket_events(ticket_id);

-- ── AIRLINE CONTACTS (base de dados de contatos) ─
