-- ── SLA METRICS VIEW ─────────────────────────────
create or replace view public.emergency_sla_daily as
select
  date_trunc('day', created_at) as day,
  count(*) as total_tickets,
  count(*) filter (where sla_breached = false and status = 'resolved') as sla_met,
  count(*) filter (where sla_breached = true) as sla_breached_count,
  avg(response_time_seconds) as avg_response_seconds,
  avg(satisfaction_rating) as avg_satisfaction,
  round(count(*) filter (where sla_breached = false and status = 'resolved')::numeric
    / nullif(count(*),0) * 100, 1) as sla_rate_percent
from public.emergency_tickets
group by date_trunc('day', created_at)
order by day desc;

-- ── RLS ──────────────────────────────────────────
alter table public.agencies              enable row level security;
alter table public.emergency_tickets     enable row level security;
alter table public.ticket_events         enable row level security;

-- Agências veem apenas seus próprios tickets
create policy "Agency sees own tickets"
  on public.emergency_tickets for select
  using (agency_id = (
    select id from public.agencies where contact_email = auth.jwt()->>'email' limit 1
  ));

create policy "Agency creates own tickets"
  on public.emergency_tickets for insert
  with check (agency_id = (
    select id from public.agencies where contact_email = auth.jwt()->>'email' limit 1
  ));

-- Dados públicos de contatos de aéreas e hotéis
create policy "Anyone can read airline contacts"
  on public.airline_contacts for select using (true);
